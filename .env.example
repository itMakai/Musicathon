PORT=5000

# Optional API keys. The app runs with demo fallbacks when these are absent.
# SONGSTATS  → real current top tracks + popularity (drives the setlist)
# MUSIXMATCH → real song lyrics (primary lyrics source; copyright shown)
# JAMBASE    → real upcoming concert (venue + date)
# ELEVENLABS → real narrated podcast voice (via /api/narration)
# LALAL      → instrumental hook extraction (demo only)
# CYANITE    → AI music analysis: mood/genre/energy/BPM/key (via /api/track-analysis)
SONGSTATS_API_KEY=
MUSIXMATCH_API_KEY=
JAMBASE_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
LALAL_API_KEY=
CYANITE_API_KEY=
